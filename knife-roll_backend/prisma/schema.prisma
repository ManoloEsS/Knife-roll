// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ShiftStatus {
  available
  assigned
  pending
}

enum ShiftTime {
  breakfast
  lunch
  dinner
}

model User {
  id Int @id @default(autoincrement())
  email String @unique
  name String?
  password String
  mustChangePassword Boolean @default(true) @map("must_change_password")
  admin Boolean @default(false)
  schedules Schedule[]
  scheduledHours Int @default(0) @map("scheduled_hours")
  shifts Shift[]
  basePayRate Decimal @default(0) @map("base_pay_rate")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Schedule {
  id Int @id @default(autoincrement())
  startDate DateTime @map("start_date")
  endDate DateTime @map("end_date")
  createdBy Int @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  shifts Shift[]

  @@unique([startDate])
  @@map("schedules")
}

model Shift {
  id Int @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  shiftTime ShiftTime @map("shift_time")
  date DateTime
  scheduleId Int @map("schedule_id")
  userId Int? @map("user_id") 
  stationName String @map("station")
  status ShiftStatus @default(available)
  incentive Decimal? @default(0)

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  station Station @relation(fields: [stationName], references: [name], onDelete: Restrict)

  @@map("shifts")
}

model Station {
  id Int @id @default(autoincrement())
  name String @unique
  shifts Shift[] // Virtual relation field — not a DB column, but enables include: { shifts: true } and nested writes

  @@map("stations")
}


