// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id Int @id @default(autoincrement())
  email String @unique
  name String?
  admin Boolean
  schedules Schedule[]
  scheduledHours Int @default(0) @map("scheduled_hours")
  shifts Shift[]

  @@map("users")
}

model Schedule {
  id Int @id @default(autoincrement())
  startDate DateTime @map("start_date")
  endDate DateTime @map("end_date")
  createdBy Int @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  shifts Shift[]

  @@map("schedules")
}

model Shift {
  id Int @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  startTime DateTime @map("start_time")
  endTime DateTime @map("end_time")
  scheduleId Int @map("schedule_id")
  userId Int? @map("user_id") 
  stationName String @map("station")
  available Boolean @default(true)

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  station Station @relation(fields: [stationName], references: [name], onDelete: Restrict)

  @@map("shifts")
}

model Station {
  id Int @id @default(autoincrement())
  name String @unique
  shifts Shift[]

  @@map("stations")
}


